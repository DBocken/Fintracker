# Fintracker MCP POC — server environment
# Supabase project that holds the `mcp_aggregate_snapshots` table.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SERVICE ROLE key (server-side secret, bypasses RLS). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Port the HTTP server listens on.
PORT=8080
